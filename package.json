{
  "name": "luis-boniche-portfolio",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build:css": "tailwindcss -i ./tailwind.css -o ./assets/css/built.css --minify",
    "watch:css": "tailwindcss -i ./tailwind.css -o ./assets/css/built.css --watch",
    "validate:jsdoc": "jsdoc assets/js/*.js --pedantic --destination /tmp/jsdoc"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.17",
    "@tailwindcss/forms": "^0.5.9",
    "@tailwindcss/container-queries": "^0.1.1",
    "jsdoc": "^4.0.4"
  }
}
